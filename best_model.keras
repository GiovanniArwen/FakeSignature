   "source": [
    "import os\n",
    "\n",
    "train_dir = r'D:\\BFCAI Level 3 T2\\AI\\Neural Networks\\Project\\Fake signature\\Fake signature\\Test'\n",
    "\n",
    "data_train['image_path'] = data_train.apply(\n",
    "    lambda row: os.path.join(train_dir, row['person'], row['image_name']),\n",
    "    axis=1\n",
    ")"
   ]
  },
